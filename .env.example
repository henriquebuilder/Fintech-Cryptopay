# ==========================================
# CryptoPay - Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores

# API URL (desenvolvimento)
VITE_API_URL=http://localhost:5173/api

# ==========================================
# Integrações (Opcional - modo demo funciona sem)
# ==========================================

# WalletConnect Project ID (para conexão Web3)
# Obtenha em: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Chave PIX para recebimentos
PIX_KEY=

# ==========================================
# Cloudflare (configurado automaticamente)
# ==========================================
# Estas variáveis são injetadas pelo Cloudflare Workers
# DATABASE_URL - Conexão D1
# R2_BUCKET - Storage de arquivos
